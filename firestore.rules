rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Get current user document fields from the 'users' collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    // 1. Users Collection rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      // Allow registration profile creation: student (public), faculty (needs passcode), admin (needs passcode), or by existing Admin
      allow create: if (isUser(uid) && (
        request.resource.data.role == 'student' || 
        (request.resource.data.role == 'faculty' && request.resource.data.authCode == 'faculty123') ||
        (request.resource.data.role == 'admin' && request.resource.data.authCode == 'admin123')
      )) || isAdmin();
      // Restrict writes to role field to Admin only
      allow update: if isUser(uid) && 
        (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    // 2. Departments Collection
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 3. Courses Collection
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Helper function: Check if user is the assigned faculty for a specific course
    function isCourseFaculty(courseId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/courses/$(courseId)) &&
        get(/databases/$(database)/documents/courses/$(courseId)).data.facultyId == request.auth.uid;
    }

    // 4. Attendance Collection
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      // Allow faculty to write attendance only for their courses
      allow create, delete: if isCourseFaculty(request.resource.data.courseId) || isAdmin();
      // Allow updates if student is scanning (adding their uid to studentsPresent array) or faculty of the course
      allow update: if isCourseFaculty(resource.data.courseId) || 
        (isAuthenticated() && 
         request.resource.data.studentsPresent.difference(resource.data.studentsPresent).size() == 1 &&
         request.resource.data.studentsPresent.hasAll(resource.data.studentsPresent) &&
         request.auth.uid in request.resource.data.studentsPresent) || 
        isAdmin();
    }

    // 5. Assignments Collection
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      // Allow faculty to write assignments only for their courses
      allow create: if isCourseFaculty(request.resource.data.courseId) || isAdmin();
      allow update: if isCourseFaculty(resource.data.courseId) || isAdmin();
      allow delete: if isCourseFaculty(resource.data.courseId) || isAdmin();
    }

    // 6. Submissions Collection
    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        isCourseFaculty(get(/databases/$(database)/documents/assignments/$(resource.data.assignmentId)).data.courseId) ||
        isAdmin()
      );
      // Students can create their own submissions
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId;
      // Allow update if student updating submission or faculty grading
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        isCourseFaculty(get(/databases/$(database)/documents/assignments/$(resource.data.assignmentId)).data.courseId) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.studentId || isAdmin());

      // Feedback sub-collection inside submissions
      match /feedback/{feedbackId} {
        allow read: if isAuthenticated();
        allow write: if isCourseFaculty(get(/databases/$(database)/documents/assignments/$(get(/databases/$(database)/documents/submissions/$(submissionId)).data.assignmentId)).data.courseId) || isAdmin();
      }
    }

    // 7. Timetable Collection
    match /timetable/{timetableId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 8. Notices Collection
    match /notices/{noticeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 9. Leaves Collection
    match /leaves/{leaveId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        getUserData().role == 'faculty' || 
        getUserData().role == 'admin'
      );
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId;
      // Faculty and Admins can approve/reject leaves
      allow update: if getUserData().role == 'faculty' || getUserData().role == 'admin';
      allow delete: if isAdmin();
    }

    // 10. Fee Records Collection
    match /fee_records/{feeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || getUserData().role == 'admin');
      allow write: if isAdmin();
    }
  }
}
