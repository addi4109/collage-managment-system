# Port the backend server will listen on
PORT=5000

# MongoDB Atlas cluster connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Secret key used for signing JWT access tokens
JWT_SECRET=your_super_secret_jwt_sign_key_minimum_32_characters

# Node Environment state (development, production, or testing)
NODE_ENV=production

# Comma-separated list of allowed CORS domains for production
ALLOWED_ORIGINS=https://your-app-frontend.vercel.app,http://localhost:3000,http://localhost:3001
